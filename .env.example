# ============================================================
# 智能记账系统 - 环境变量配置
# 复制此文件为 .env 并填入真实的API密钥
# ============================================================

# ---------- 百度OCR（文字识别）----------
# 申请地址: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=your_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_ocr_secret_key

# ---------- 百度语音识别 ----------
# 申请地址: https://console.bce.baidu.com/ai/#/ai/speech/overview/index
BAIDU_VOICE_API_KEY=your_voice_api_key
BAIDU_VOICE_SECRET_KEY=your_voice_secret_key

# ---------- 百度千帆大模型（AI对话/智能解析）----------
# 申请地址: https://console.bce.baidu.com/qianfan/overview
BAIDU_QIANFAN_API_KEY=your_qianfan_api_key
BAIDU_QIANFAN_MODEL=ernie-lite-pro-128k

# ---------- 服务端口 ----------
PORT=3001
